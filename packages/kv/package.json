{
  "name": "@tagcache/kv",
  "version": "0.1.0",
  "description": "Cloudflare KV backend for tagcache",
  "keywords": ["tagcache", "kv", "cloudflare-workers", "edge"],
  "author": "Minchul Kwon <mstorm@mstorm.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tagcache/tagcache.git",
    "directory": "packages/kv"
  },
  "bugs": { "url": "https://github.com/tagcache/tagcache/issues" },
  "homepage": "https://github.com/tagcache/tagcache/tree/main/packages/kv#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "size": "size-limit"
  },
  "peerDependencies": {
    "tagcache": "workspace:*"
  },
  "devDependencies": {
    "tagcache": "workspace:*",
    "@cloudflare/workers-types": "^4.20241127.0"
  },
  "size-limit": [
    {
      "name": "@tagcache/kv",
      "path": "dist/index.js",
      "limit": "450 B",
      "brotli": false
    }
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
